---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const winners = [
  {
    id: '1',
    name: 'María G.',
    province: 'La Habana',
    prize: 'iPhone 15 Pro Max',
    image: 'https://images.unsplash.com/photo-1556656793-08538906a9f8?w=600',
    ticketNumber: 234,
    date: '2026-06-15',
    photo: 'https://images.unsplash.com/photo-1590479773265-7464e5d48118?w=400',
  },
  {
    id: '2',
    name: 'Carlos R.',
    province: 'Santiago de Cuba',
    prize: 'Samsung Smart TV 55"',
    image: 'https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?w=600',
    ticketNumber: 891,
    date: '2026-06-01',
    photo: 'https://images.unsplash.com/photo-1574263867128-a3d5c1b1decc?w=400',
  },
  {
    id: '3',
    name: 'Ana L.',
    province: 'Camagüey',
    prize: 'PlayStation 5',
    image: 'https://images.unsplash.com/photo-1606144042614-b2417e99c4e3?w=600',
    ticketNumber: 156,
    date: '2026-05-20',
    photo: 'https://images.unsplash.com/photo-1612287230202-1ff1d85d1bdf?w=400',
  },
  {
    id: '4',
    name: 'Roberto M.',
    province: 'Santa Clara',
    prize: 'MacBook Air M3',
    image: 'https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=600',
    ticketNumber: 423,
    date: '2026-05-10',
    photo: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=400',
  },
  {
    id: '5',
    name: 'Laura P.',
    province: 'Holguín',
    prize: 'Samsung Galaxy S24 Ultra',
    image: 'https://images.unsplash.com/photo-1610945415295-d9bbf067e59c?w=600',
    ticketNumber: 678,
    date: '2026-04-28',
    photo: 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=400',
  },
  {
    id: '6',
    name: 'Pedro S.',
    province: 'Guantánamo',
    prize: 'Smart TV 65" OLED',
    image: 'https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?w=600',
    ticketNumber: 999,
    date: '2026-04-15',
    photo: 'https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?w=400',
  },
];

const stats = {
  totalWinners: winners.length,
  totalPrizes: '$15,000+',
  provinces: 6,
};
---

<Layout title="Ganadores">
  <Header />

  <main class="bg-dark py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12 text-center">
        <h1 class="mb-4 text-4xl font-extrabold text-white">Nuestros Ganadores</h1>
        <p class="mb-8 text-lg text-neutral-400">
          Todos los sorteos se realizan en vivo y los ganadores son publicados con total transparencia.
        </p>

        <!-- Stats -->
        <div class="mx-auto grid max-w-2xl grid-cols-3 gap-4">
          <div class="rounded-xl border border-dark-border bg-dark-card p-4">
            <p class="text-3xl font-bold text-gold">{stats.totalWinners}</p>
            <p class="text-sm text-neutral-500">Ganadores</p>
          </div>
          <div class="rounded-xl border border-dark-border bg-dark-card p-4">
            <p class="text-3xl font-bold text-gold">{stats.totalPrizes}</p>
            <p class="text-sm text-neutral-500">En premios</p>
          </div>
          <div class="rounded-xl border border-dark-border bg-dark-card p-4">
            <p class="text-3xl font-bold text-gold">{stats.provinces}</p>
            <p class="text-sm text-neutral-500">Provincias</p>
          </div>
        </div>
      </div>

      <!-- Winners Grid -->
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {winners.map((winner) => (
          <article class="card-premium overflow-hidden">
            <!-- Prize Image -->
            <div class="relative aspect-video overflow-hidden">
              <img
                src={winner.image}
                alt={`Premio: ${winner.prize}`}
                class="h-full w-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark/80 to-transparent"></div>
              <span class="absolute top-3 left-3 rounded-full border border-gold/30 bg-gold/20 px-3 py-1 text-xs font-semibold text-gold">
                Ganador
              </span>
            </div>

            <!-- Winner Info -->
            <div class="p-5">
              <div class="mb-4 flex items-center gap-3">
                <img
                  src={winner.photo}
                  alt={winner.name}
                  class="h-12 w-12 rounded-full border-2 border-gold object-cover"
                />
                <div>
                  <h3 class="font-bold text-white">{winner.name}</h3>
                  <p class="text-xs text-neutral-500">{winner.province}</p>
                </div>
              </div>

              <div class="mb-4 space-y-2">
                <div class="flex items-center justify-between rounded-lg bg-dark p-3">
                  <span class="text-sm text-neutral-500">Premio</span>
                  <span class="text-sm font-semibold text-gold">{winner.prize}</span>
                </div>
                <div class="flex items-center justify-between rounded-lg bg-dark p-3">
                  <span class="text-sm text-neutral-500">Número ganador</span>
                  <span class="text-sm font-bold text-white">#{winner.ticketNumber}</span>
                </div>
                <div class="flex items-center justify-between rounded-lg bg-dark p-3">
                  <span class="text-sm text-neutral-500">Fecha del sorteo</span>
                  <span class="text-sm text-white">
                    {new Date(winner.date).toLocaleDateString('es-ES', {
                      day: 'numeric',
                      month: 'long',
                      year: 'numeric',
                    })}
                  </span>
                </div>
              </div>

              <div class="flex items-center gap-2 text-xs text-neutral-500">
                <svg class="h-4 w-4 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Premio entregado y verificado
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center">
        <h2 class="mb-4 text-2xl font-bold text-white">¿Quieres ser el próximo ganador?</h2>
        <p class="mb-6 text-neutral-400">Participa en nuestras rifas activas y gana increíbles premios.</p>
        <a
          href="/raffles"
          class="inline-flex items-center gap-2 rounded-lg bg-gold px-8 py-3 text-lg font-bold text-dark transition-colors hover:bg-gold-light"
        >
          Ver Rifas Activas
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
