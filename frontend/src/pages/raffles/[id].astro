---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';
import type { Raffle } from '../../types';

const { id } = Astro.params;

let raffle: Raffle | null = null;

if (id && supabase) {
  const { data } = await supabase
    .from('raffles')
    .select('*')
    .eq('id', id)
    .single();
  raffle = data;
}

if (!raffle) {
  raffle = {
    id: id || '1',
    title: 'iPhone 15 Pro Max',
    description: 'Gana el nuevo iPhone 15 Pro Max de 256GB en color titanio negro. Este dispositivo cuenta con el potente chip A17 Pro, sistema de cámara de triple lente de 48MP, y pantalla Super Retina XDR de 6.7 pulgadas. Incluye cargador y caja original.',
    image_url: 'https://images.unsplash.com/photo-1695048133142-1a20484d2569?w=800',
    ticket_price: 50,
    total_tickets: 100,
    sold_tickets: 67,
    status: 'active',
    draw_date: '2026-08-15',
    created_at: '2026-07-01',
  };
}

const availableTickets = raffle.total_tickets - raffle.sold_tickets;
const soldPercentage = (raffle.sold_tickets / raffle.total_tickets) * 100;

if (raffle.status !== 'active') {
  return Astro.redirect('/raffles');
}
---

<Layout title={raffle.title}>
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <a href="/raffles" class="mb-8 inline-flex items-center gap-2 text-primary hover:underline">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      Volver a Rifas
    </a>

    <div class="grid gap-10 lg:grid-cols-5">
      <div class="lg:col-span-3">
        <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white">
          <img
            src={raffle.image_url}
            alt={raffle.title}
            class="aspect-video w-full object-cover"
          />
        </div>
      </div>

      <div class="lg:col-span-2">
        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <span class="mb-3 inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">
            Activa
          </span>

          <h1 class="mb-3 text-2xl font-extrabold text-gray-900">{raffle.title}</h1>
          <p class="mb-6 leading-relaxed text-gray-600">{raffle.description}</p>

          <div class="mb-6 space-y-4">
            <div class="flex items-center justify-between rounded-lg bg-gray-50 px-4 py-3">
              <span class="text-gray-500">Precio por boleto</span>
              <span class="text-2xl font-bold text-primary">${raffle.ticket_price.toFixed(2)}</span>
            </div>

            <div class="flex items-center justify-between rounded-lg bg-gray-50 px-4 py-3">
              <span class="text-gray-500">Boletos disponibles</span>
              <span class="text-lg font-bold text-green-600">{availableTickets}</span>
            </div>

            <div class="flex items-center justify-between rounded-lg bg-gray-50 px-4 py-3">
              <span class="text-gray-500">Fecha del sorteo</span>
              <span class="font-semibold text-gray-900">
                {new Date(raffle.draw_date).toLocaleDateString('es-ES', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </span>
            </div>
          </div>

          <div class="mb-6">
            <div class="mb-2 flex items-center justify-between text-sm">
              <span class="text-gray-500">Progreso de venta</span>
              <span class="font-medium">{raffle.sold_tickets} / {raffle.total_tickets} vendidos</span>
            </div>
            <div class="h-3 overflow-hidden rounded-full bg-gray-200">
              <div
                class="h-full rounded-full bg-accent transition-all duration-500"
                style={`width: ${soldPercentage}%`}
              >
              </div>
            </div>
          </div>

          <button
            class="w-full rounded-xl bg-primary py-4 text-lg font-bold text-white transition-colors hover:bg-primary-dark disabled:cursor-not-allowed disabled:opacity-50"
            disabled={availableTickets === 0}
          >
            {availableTickets === 0 ? 'Agotado' : `Comprar Boleto - $${raffle.ticket_price.toFixed(2)}`}
          </button>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
