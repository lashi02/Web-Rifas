---
interface Participant {
  id: string;
  name: string;
  phone: string;
  tickets: number[];
  status: 'confirmed' | 'pending';
  purchasedAt: string;
}

const mockParticipants: Participant[] = [
  {
    id: '1',
    name: 'Carlos M.',
    phone: '+53 5555 1234',
    tickets: [45, 46, 47, 123, 456],
    status: 'confirmed',
    purchasedAt: '2026-07-10',
  },
  {
    id: '2',
    name: 'María G.',
    phone: '+1 (305) 555-0123',
    tickets: [77, 234, 567, 891],
    status: 'confirmed',
    purchasedAt: '2026-07-12',
  },
  {
    id: '3',
    name: 'Roberto L.',
    phone: '+53 5555 5678',
    tickets: [12, 88, 333],
    status: 'confirmed',
    purchasedAt: '2026-07-14',
  },
  {
    id: '4',
    name: 'Ana P.',
    phone: '+1 (786) 555-0456',
    tickets: [99, 100, 201, 444, 678, 999],
    status: 'confirmed',
    purchasedAt: '2026-07-15',
  },
  {
    id: '5',
    name: 'Pedro S.',
    phone: '+53 5555 9012',
    tickets: [155, 288],
    status: 'pending',
    purchasedAt: '2026-07-16',
  },
];

const confirmedCount = mockParticipants.filter(p => p.status === 'confirmed').length;
const totalNumbers = mockParticipants.reduce((sum, p) => sum + p.tickets.length, 0);
---

<div class="card-premium overflow-hidden">
  <div class="flex items-center justify-between border-b border-dark-border p-6">
    <div>
      <h2 class="text-xl font-bold text-white">Participantes Confirmados</h2>
      <p class="mt-1 text-sm text-neutral-400">{confirmedCount} participantes · {totalNumbers} números confirmados</p>
    </div>
    <span class="rounded-full bg-green/20 px-3 py-1 text-xs font-semibold text-green">
      {confirmedCount} confirmados
    </span>
  </div>

  <div class="divide-y divide-dark-border">
    {mockParticipants.map((participant) => (
      <div class="flex items-center justify-between p-4 transition-colors hover:bg-dark-hover">
        <div class="flex items-center gap-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-dark text-sm font-bold text-gold">
            {participant.name.charAt(0)}
          </div>
          <div>
            <p class="font-semibold text-white">{participant.name}</p>
            <p class="text-xs text-neutral-500">{participant.phone}</p>
          </div>
        </div>

        <div class="text-right">
          <div class="flex flex-wrap justify-end gap-1">
            {participant.tickets.slice(0, 3).map((num) => (
              <span class="rounded bg-dark px-2 py-0.5 text-xs font-medium text-gold">
                {num}
              </span>
            ))}
            {participant.tickets.length > 3 && (
              <span class="rounded bg-dark px-2 py-0.5 text-xs text-neutral-500">
                +{participant.tickets.length - 3}
              </span>
            )}
          </div>
          <p class={`mt-1 text-xs ${
            participant.status === 'confirmed' ? 'text-green' : 'text-amber'
          }`}>
            {participant.status === 'confirmed' ? 'Confirmado' : 'Pendiente'}
          </p>
        </div>
      </div>
    ))}
  </div>

  <div class="border-t border-dark-border p-4 text-center">
    <p class="text-sm text-neutral-500">
      Los datos se muestran parcialmente para proteger la privacidad de los participantes.
    </p>
  </div>
</div>
