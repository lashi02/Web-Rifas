---
const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/raffles', label: 'Rifas' },
];
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="text-2xl font-bold text-primary">
      <span class="text-accent">Web</span>Rifas
    </a>

    <ul class="flex items-center gap-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-gray-600 transition-colors hover:text-primary"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
