---
interface Props {
  drawDate: string;
  ticketPrice: number;
  totalTickets: number;
}

const { drawDate, ticketPrice, totalTickets } = Astro.props;

const rules = [
  {
    title: 'Fecha del Sorteo',
    content: `El sorteo se realizará el ${new Date(drawDate).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })} en vivo por nuestras redes sociales.`,
    icon: 'calendar',
  },
  {
    title: 'Método del Sorteo',
    content: 'El sorteo se realizará en vivo por Instagram/Facebook/YouTube. Se usará un sistema aleatorio certificado para seleccionar el número ganador.',
    icon: 'video',
  },
  {
    title: 'Precio y Forma de Pago',
    content: `Cada número cuesta $${ticketPrice.toFixed(2)} USD. Se puede pagar por Zelle, transferencia bancaria u otro medio acordado. El pago debe confirmarse antes de que la reserva venza.`,
    icon: 'payment',
  },
  {
    title: 'Límite de Reserva',
    content: 'Los números reservados tienen un plazo de 30 minutos para confirmar el pago. Si el pago no se confirma en ese tiempo, los números vuelven a estar disponibles.',
    icon: 'clock',
  },
  {
    title: 'Confirmación de Pago',
    content: 'Los números quedan confirmados solo después de que el administrador verifique el pago. Recibirás una confirmación por WhatsApp.',
    icon: 'check',
  },
  {
    title: 'Entrega del Premio',
    content: 'El premio se entrega personalmente en la provincia del ganador o se acuerda un envío. La entrega se graba como prueba de transparencia.',
    icon: 'gift',
  },
  {
    title: 'Lista de Participantes',
    content: 'La lista de participantes confirmados se publica en esta página para total transparencia. Solo se muestran datos parciales para proteger la privacidad.',
    icon: 'list',
  },
  {
    title: 'Condiciones Generales',
    content: 'Cada número solo puede ser vendido una vez. El sistema bloquea los números reservados para evitar ventas duplicadas. El sorteo es definitivo e inapelable.',
    icon: 'shield',
  },
];
---

<div class="card-premium overflow-hidden">
  <div class="border-b border-dark-border p-6">
    <h2 class="text-xl font-bold text-white">Reglas del Sorteo</h2>
    <p class="mt-1 text-sm text-neutral-400">Lee todas las condiciones antes de participar</p>
  </div>

  <div class="divide-y divide-dark-border">
    {rules.map((rule, index) => (
      <details class="group" open={index === 0}>
        <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 transition-colors hover:bg-dark-hover">
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-gold/10">
              {rule.icon === 'calendar' && (
                <svg class="h-4 w-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              )}
              {rule.icon === 'video' && (
                <svg class="h-4 w-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              )}
              {rule.icon === 'payment' && (
                <svg class="h-4 w-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
              )}
              {rule.icon === 'clock' && (
                <svg class="h-4 w-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              )}
              {rule.icon === 'check' && (
                <svg class="h-4 w-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              )}
              {rule.icon === 'gift' && (
                <svg class="h-4 w-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
                </svg>
              )}
              {rule.icon === 'list' && (
                <svg class="h-4 w-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                </svg>
              )}
              {rule.icon === 'shield' && (
                <svg class="h-4 w-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              )}
            </div>
            <span class="font-semibold text-white">{rule.title}</span>
          </div>
          <svg class="h-5 w-5 flex-shrink-0 text-neutral-500 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-5 pb-5 pl-16 text-neutral-400">
          {rule.content}
        </div>
      </details>
    ))}
  </div>
</div>
